{
  "name": "reddoor-website",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "concurrently \"pnpm:vite:dev\" \"pnpm:slicemachine\" --prefix-colors blue,magenta",
    "vite:dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . --plugin prettier-plugin-svelte . && eslint .",
    "format": "prettier --write . --plugin prettier-plugin-svelte .",
    "test:smoke": "playwright install chromium && playwright test",
    "slicemachine": "start-slicemachine",
    "vite:devHost": "vite dev --host --port 8888"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@slicemachine/adapter-sveltekit": "^0.3.96",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.65.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@zerodevx/svelte-img": "^2.1.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "slice-machine-ui": "^2.21.3",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-svelte-plugin": "^0.3.52",
    "vite": "^8.0.16"
  },
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@lucide/svelte": "^1.20.0",
    "@prismicio/client": "^7.21.8",
    "@prismicio/svelte": "^2.2.1",
    "@reddoorla/maintenance": "^0.40.0",
    "fuse.js": "^7.4.2",
    "svelte-gestures": "^5.2.2"
  }
}
